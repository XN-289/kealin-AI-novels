# Kealin AI Novels 配置文件
# 复制此文件为 .env 并填入你的 API Key

# 主模型配置（用于大纲、章节、正文生成）
PRIMARY_API_KEY=sk-your-key-here
PRIMARY_API_ENDPOINT=https://api.deepseek.com/v1/chat/completions
PRIMARY_MODEL=deepseek-chat

# 辅助模型配置（用于AI迭代优化，可用低成本模型）
SECONDARY_API_KEY=
SECONDARY_API_ENDPOINT=https://api.deepseek.com/v1/chat/completions
SECONDARY_MODEL=deepseek-chat

# 服务配置
PORT=20000
HOST=0.0.0.0
DEBUG=true
